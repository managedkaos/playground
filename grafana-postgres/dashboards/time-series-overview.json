{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "CPU Usage by Host",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 10,
            "pointSize": 5,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "rawSql": "SELECT\n  $__timeGroup(time, $__interval) AS time,\n  host,\n  avg(usage_pct) AS usage_pct\nFROM cpu_usage\nWHERE $__timeFilter(time)\nGROUP BY 1, host\nORDER BY 1",
          "format": "table",
          "refId": "A"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "title": "Memory Usage by Host",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "" },
      "fieldConfig": {
        "defaults": {
          "unit": "decgbytes",
          "min": 0,
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 10,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "rawSql": "SELECT\n  $__timeGroup(time, $__interval) AS time,\n  host,\n  avg(used_gb) AS used_gb\nFROM memory_usage\nWHERE $__timeFilter(time)\nGROUP BY 1, host\nORDER BY 1",
          "format": "table",
          "refId": "A"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "title": "HTTP Request Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "showPoints": "never",
            "stacking": { "mode": "normal" }
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "rawSql": "SELECT\n  $__timeGroup(time, $__interval) AS time,\n  endpoint,\n  count(*)::float / EXTRACT(EPOCH FROM interval '$__interval') AS rps\nFROM http_requests\nWHERE $__timeFilter(time)\nGROUP BY 1, endpoint\nORDER BY 1",
          "format": "table",
          "refId": "A"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "title": "Response Time (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "" },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 0,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "rawSql": "SELECT\n  $__timeGroup(time, $__interval) AS time,\n  percentile_cont(0.50) WITHIN GROUP (ORDER BY response_ms) AS p50,\n  percentile_cont(0.95) WITHIN GROUP (ORDER BY response_ms) AS p95,\n  percentile_cont(0.99) WITHIN GROUP (ORDER BY response_ms) AS p99\nFROM http_requests\nWHERE $__timeFilter(time)\nGROUP BY 1\nORDER BY 1",
          "format": "table",
          "refId": "A"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "title": "Error Rate (4xx + 5xx)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 20,
            "showPoints": "never"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.05 },
              { "color": "red", "value": 0.10 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "targets": [
        {
          "rawSql": "SELECT\n  $__timeGroup(time, $__interval) AS time,\n  endpoint,\n  count(*) FILTER (WHERE status_code >= 400)::float / NULLIF(count(*), 0) AS error_rate\nFROM http_requests\nWHERE $__timeFilter(time)\nGROUP BY 1, endpoint\nORDER BY 1",
          "format": "table",
          "refId": "A"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "title": "Request Count by Status Code",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "" },
      "targets": [
        {
          "rawSql": "SELECT\n  status_code::text AS status,\n  count(*) AS count\nFROM http_requests\nWHERE $__timeFilter(time)\nGROUP BY status_code\nORDER BY status_code",
          "format": "table",
          "refId": "A"
        }
      ],
      "options": {
        "legend": { "displayMode": "list", "placement": "right" },
        "pieType": "donut",
        "reduceOptions": { "calcs": ["sum"] }
      }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["postgres", "time-series"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Time Series Overview",
  "uid": "ts-overview",
  "version": 1
}
